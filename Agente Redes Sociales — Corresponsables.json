    {
      "parameters": {
        "jsCode": "// ============================================\n// EXTRAER TEXTO DEL POST GENERADO POR LA IA\n// ============================================\n// La API de OpenAI puede devolver la respuesta en dos formatos distintos\n// según la versión del modelo o del nodo n8n. Con ?? probamos el primero\n// y si viene vacío o undefined, automáticamente usamos el segundo.\nconst aiResponse = \n  $input.item.json.message?.content        // Formato nuevo (gpt-4o, gpt-4)\n  ?? $input.item.json.choices?.[0]?.message?.content  // Formato legacy (completions)\n  ?? '';                                   // Fallback: string vacío si falla todo\n\n// ============================================\n// LIMPIAR Y ESCAPAR EL TEXTO\n// ============================================\nconst postEscapado = aiResponse\n  .replace(/\\*\\*/g, '')        // Elimina asteriscos markdown (**texto**)\n  .replace(/\\\\/g, '\\\\\\\\')     // Escapa barras invertidas primero\n  .replace(/\"/g, '\\\\\"')       // Escapa comillas dobles para GraphQL\n  .replace(/\\n/g, '\\\\n')     // Escapa saltos de línea para GraphQL\n  .replace(/\\r/g, '\\\\r');    // Escapa retornos de carro para GraphQL\n\n// ============================================\n// OBTENER URL DE IMAGEN Y AUTOR DESDE WP\n// ============================================\n// El nodo WP puede devolver array o objeto directo, cubrimos ambos casos\nconst wpMedia = $('🖼️ WP — Obtener imagen destacada').item.json[0] \n  ?? $('🖼️ WP — Obtener imagen destacada').item.json;\n\n// URL permanente de la imagen destacada del post en WordPress\nconst imagenUrl = wpMedia.guid?.rendered ?? wpMedia.source_url ?? '';\n\n// Nombre del autor/entrevistado extraído del título del media en WP\nconst autor = wpMedia.title?.rendered ?? '';\n\n// ============================================\n// CONSTRUIR EL OBJETO DE SALIDA\n// ============================================\nreturn [{\n  json: {\n    // Texto limpio y escapado listo para publicar en redes y guardar en Airtable\n    linkedinPost: postEscapado,\n\n    // URL de la imagen destacada para adjuntar en Buffer\n    imagenUrl: imagenUrl,\n\n    // Nombre del autor o entrevistado\n    autor: autor,\n\n    // ID interno de Airtable para saber qué fila actualizar\n    airtableId: $('📋 Airtable — Buscar pendientes').item.json.id,\n\n    // Título del artículo para identificar la ejecución en el historial\n    titulo: $('📋 Airtable — Buscar pendientes').item.json['Título periodístico']\n  }\n}];;"
      },
      "id": "d23e1351-29dc-42ff-8740-547a9b29592f",
